# Copy this file to .env and fill values

# =====================
# Backend (FastAPI)
# =====================

# Providers — set corresponding API keys for the provider(s) you use
# OpenAI
OPENAI_API_KEY=
# Google Gemini (either one is fine)
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# Anthropic Claude
# ANTHROPIC_API_KEY=

# Provider selection (defaults shown)
# CHAT_PROVIDER can be: openai | gemini | anthropic
CHAT_PROVIDER=openai
# EMBEDDING_PROVIDER can be: openai | gemini
EMBEDDING_PROVIDER=openai

# Default models (can be overridden via Settings UI)
# OpenAI examples:
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Gemini examples:
# GEMINI_CHAT_MODEL=gemini-1.5-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004
# Anthropic examples:
# ANTHROPIC_CHAT_MODEL=claude-3-haiku-20240307

# RAG parameters (optional; can be changed in Settings UI)
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=4
EMBEDDING_DIM=1536

# Data paths (used by backend)
DATA_DIR=backend/data

# =====================
# Database (PostgreSQL)
# =====================
POSTGRES_USER=autollm
POSTGRES_PASSWORD=postgres
POSTGRES_DB=autollm
POSTGRES_PORT=5050
POSTGRES_HOST=postgres   # backend container will resolve the docker service and talk to port 5432 internally

# =====================
# Authentication / JWT
# =====================
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# =====================
# Frontend (Next.js)
# =====================

# Frontend will call backend via this base URL (from the browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
